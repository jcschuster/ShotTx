# Debug of Tableaux

```elixir
Mix.install([
  {:shot_main, path: Path.join(__DIR__, "..")},
  {:kino, "~> 0.19.0"}
])
```

## Setup

```elixir
import ShotDs.Hol.Definitions
import ShotMain.Generation
import ShotDs.Util.Formatter
alias ShotDs.Data.Type
```

```elixir
form =
  Kino.Control.form(
    [
      name: Kino.Input.checkbox("Debug", default: true)
    ],
    report_changes: true
  )

Kino.listen(form, fn event ->
  if event.data.name == true do
    Logger.configure(level: :debug)
  else
    Logger.configure(level: :warning)
  end
end)

Logger.configure(level: :debug)
form
```

