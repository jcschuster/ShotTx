# Evaluating Model Classes

```elixir
Mix.install([
  {:shot_tx, path: Path.join(__DIR__, "..")},
  {:kino, "~> 0.19.0"},
  {:kino_atp_client, "~> 0.1.3"}
])
```

## Setup

```elixir
import ShotTx.Prover
import ShotDs.Hol.Sigils
alias ShotDs.Tptp
```

```elixir
defmodule Util do
  def render res do
    case res do
      {:thm, proof} ->
        frame = Kino.Frame.new()
        Kino.render(frame)
        diagram = proof |> ShotTx.Proof.to_mermaid |> Kino.Mermaid.new
        Kino.Frame.render frame, diagram
      other -> other
    end
  end
end
```

```elixir
import Util
```

```elixir
leibniz = """
thf(leibniz_t, type, l: !>[A:$tType]: A > A > $o).
thf(leibniz_def, definition,
  l = ^[X:$o, Y:$o]: (![P:$o>$o]: ( (P @ X) => (P @ Y) ))
).
"""
```

<!-- livebook:{"branch_parent_index":0} -->

## Examples

Trivial:

```elixir
~f"![X,Y]: X | Y => Y | X" |> prove
```

requires $\mathfrak{b}$:

```elixir
~f"![X,Y]: X | Y = Y | X" |> prove
```

```elixir
res = ~p"""
#{leibniz}
thf(conj, conjecture,
  ![X,Y]: (l @ (X | Y) @ (Y | X))
).
""" |> prove
```

```elixir
render res
```

requires $\mathfrak{b}$ and $\xi$:

```elixir
res = ~f"(^[X,Y]: X | Y) = (^[X,Y]: Y | X)" |> prove
```

```elixir
leibniz_i_i = """
thf(leibniz_t, type, l: !>[A:$tType]: A > A > $o).
thf(leibniz_def, definition,
  l = ^[X:$o>$o>$o, Y:$o>$o>$o]: (![P:($o>$o>$o)>$o]: ( (P @ X) => (P @ Y) ))
).
"""
```

```elixir
res = ~p"""
#{leibniz_i_i}
thf(conj, conjecture,
  l @ (^[X,Y]: X | Y) @ (^[X,Y]: Y | X)
).
""" |> prove
```

<!-- livebook:{"output_size":"wide"} -->

```elixir
render res
```

requires $\mathfrak{b}$ and $\mathfrak{f}$:

```elixir
~f"(&) = ^[X,Y]: Y & X" |> prove
```

requires $\mathfrak{b}$:

```elixir
res = ~f"p @ a & p @ b => p @ (a & b)" |> prove
```

<!-- livebook:{"output_size":"wide"} -->

```elixir
render res
```

```elixir
with_context(~e[h:$o>$i], fn ->
  ~f"h @ (h @ $true = h @ $false) = h @ $false"
end) |> prove
```

<!-- livebook:{"continue_on_error":true} -->

```elixir
with_context(~e[h:$o>$i], fn ->
  ~f"(c @ (h @ $false)) & (h @ $true = h @ $false) => c @ (h @ $true)"
end) |> prove
```

<!-- livebook:{"continue_on_error":true} -->

```elixir
with_context(~e[h:$o>$i], fn ->
  ~f"(c @ (h @ $false)) & (h @ $true = h @ X) => c @ (h @ $true)"
end) |> prove
```

