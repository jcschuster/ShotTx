# Evaluating Model Classes

```elixir
Mix.install([
  {:shot_tx, path: Path.join(__DIR__, "..")},
  {:kino, "~> 0.19.0"},
  {:kino_atp_client, "~> 0.1.3"}
])
```

## Setup

```elixir
import ShotTx.Prover
import ShotDs.Hol.Sigils
alias ShotDs.Tptp
```

```elixir
defmodule Util do
  def render res do
    case res do
      {:thm, proof} ->
        frame = Kino.Frame.new()
        Kino.render(frame)
        diagram = proof |> ShotTx.Proof.to_mermaid |> Kino.Mermaid.new
        Kino.Frame.render frame, diagram
      other -> other
    end
  end
end
```

```elixir
import Util
```

<!-- livebook:{"branch_parent_index":0} -->

## Examples

Trivial:

```elixir
~f"![X,Y]: X | Y => Y | X" |> prove
```

requires $\mathfrak{b}$:

```elixir
~f"![X,Y]: X | Y = Y | X" |> prove
```

requires $\mathfrak{b}$ and $\xi$:

```elixir
~f"(^[X,Y]: X | Y) = (^[X,Y]: Y | X)" |> prove
```

requires $\mathfrak{b}$ and $\mathfrak{f}$:

```elixir
~f"(&) = ^[X,Y]: Y & X" |> prove
```

requires $\mathfrak{b}$:

```elixir
~f"p @ a & p @ b => p @ (a & b)" |> prove
```

```elixir
with_context(~e[h:$o>$i], fn ->
  ~f"h @ (h @ $true = h @ $false) = h @ $false"
end) |> prove
```

