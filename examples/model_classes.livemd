<!-- livebook:{"break_markdown":true} -->

Non-trivial direction of Boolean extensionality:

```elixir
~f"![A,B]: ( (A <=> B) => A = B )" |> prove
```

```elixir
~p"""
thf(h,type,
    h: ( $i > $o ) > $i ).

thf(cTHM573_pme,conjecture,
    ( ! [Xx: $i > $o,Xy: $i > $o] :
        ( ( ( h @ Xx )
          = ( h @ Xy ) )
       => ( Xx = Xy ) )
   => ? [Xg: $i > $i > $o] :
      ! [Y: $i > $o] :
      ? [X: $i] :
        ( ( Xg @ X )
        = Y ) ) ).
""" |> prove
```

```elixir
render res
```

<!-- livebook:{"attrs":"","chunks":null,"kind":"Elixir.KinoAtpClient.SystemOnTptp","livebook_object":"smart_cell"} -->

```elixir
# Generated by SystemOnTPTP Smart Cell
problem = "thf(conj,conjecture,\n    ~ ? [H: ( $i > $o ) > $i] :\n      ! [P: $i > $o,Q: $i > $o] :\n        ( ( ( H @ P )\n          = ( H @ Q ) )\n       => ( P = Q ) ) )."
system_name = "Vampire---5.0"
time_limit = 5

case AtpClient.SystemOnTptp.query_system(problem, system_name, time_limit_sec: time_limit, raw: true) do
  {:ok, result} ->
    IO.puts(result)
    result

  {:error, reason} ->
    raise "Error: #{inspect(reason)}"
end

```

```elixir
~p"""
thf(conj,conjecture,
    ~ ? [H: ( $i > $o ) > $i] :
      ! [P: $i > $o,Q: $i > $o] :
        ( ( ( H @ P )
          = ( H @ Q ) )
       => ( P = Q ) ) ).
""" |> prove
```
