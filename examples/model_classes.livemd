requires $\mathfrak{b}$:

```elixir
res = ~f"p @ a & p @ b => p @ (a & b)" |> prove
```

```elixir
with_context(~e[h:$o>$i], fn ->
  ~f"h @ (h @ $true = h @ $false) = h @ $false"
end) |> prove
```

```elixir
res = ~p"""
#{leibniz1}
thf(h_t, type, h: $o>$i).
thf(conj,conjecture,
  l @ (h @ (l @ (h @ $true) @ (h @ $false))) @ (h @ $false)
).
""" |> prove
```

```elixir
res = ~p"""
#{leibniz2}
thf(h_t, type, h: $o>$i).
thf(conj,conjecture,
  l @ (h @ (l @ (h @ $true) @ (h @ $false))) @ (h @ $false)
).
""" |> prove
```

