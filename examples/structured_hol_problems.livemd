# THM
```

```elixir
res = prove ~p"""
#{leibniz3}
thf(conj, conjecture,
  ![A:$o, B:$o]: ( (l @ A @ B) => (A <=> B) )
).
"""

format_result res
# THM
```

```elixir
res = prove ~p"""
#{andrews}
thf(conj, conjecture,
  ![A:$o, B:$o]: ( (a @ A @ B) => (A <=> B) )
).
"""

format_result res
# THM
```

```elixir
res = prove ~p"""
#{extensional}
thf(conj, conjecture,
  ![A:$o>$o, B:$o>$o]: (
    (e @ A @ B) =>
    ((A @ $true <=> B @ $true) & (A @ $false <=> B @ $false))
  )
).
"""

format_result res
# THM
```

