## Section

<!-- livebook:{"attrs":"","chunks":null,"kind":"Elixir.KinoAtpClient.SystemOnTptp","livebook_object":"smart_cell"} -->

```elixir
# Generated by SystemOnTPTP Smart Cell
problem = "thf(leibniz_t, type, l: $i > $i > $o).\nthf(leibniz_def, definition,\n  l = ^[X:$i, Y:$i]: (![P:$i>$o]: ((P @ X) => (P @ Y)))\n).\nthf(a_type, type, a: $i).\nthf(b_type, type, b: $i).\nthf(conj, conjecture,\n  (l @ a @ b) => (a = b)\n)."
system_name = "Zipperpin---2.1"
time_limit = 5

case AtpClient.SystemOnTptp.query_system(problem, system_name, time_limit_sec: time_limit, raw: true) do
  {:ok, result} ->
    IO.puts(result)
    result

  {:error, reason} ->
    raise "Error: #{inspect(reason)}"
end

```

