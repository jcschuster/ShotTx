## Non-Theorems

```elixir
res = prove ~p"""
thf(q_type, type, q : $i>$i>$o).
thf(conj,conjecture,
  (?[X:$i]: ![Y: $i]: q @ X @ Y) | (?[U:$i]: ![V:$i]: ~ (q @ V @ U))
).
"""

format_result res
# Timeout
```

```elixir
res = prove ~p"""
thf(q_type, type, q: $i>$i>$o).
thf(conj,conjecture,
  ?[Y:$i]: ![X:$i]: ( (![Z:$i]: q @ X @ Z) | ~(q @ X @ Y) )
).
"""

format_result res
# Timeout
```

```elixir
res = prove ~p"""
thf(conj, conjecture,
  ![F:$i>$i]: ?[X:$i]: F @ X = X
).
"""

format_result res
# Timeout
```

```elixir
res = prove ~p"""
#{leibniz1}
thf(conj, conjecture,
  ![F:$i>$i]: ?[X:$i]: l @ (F @ X) @ X
).
"""

format_result res
# Timeout
```

```elixir
res = prove ~p"""
#{leibniz2}
thf(conj, conjecture,
  ![F:$i>$i]: ?[X:$i]: l @ (F @ X) @ X
).
"""

format_result res
# Timeout
```

```elixir
res = prove ~p"""
#{leibniz3}
thf(conj, conjecture,
  ![F:$i>$i]: ?[X:$i]: l @ (F @ X) @ X
).
"""

format_result res
# Timeout
```

```elixir
res = prove ~p"""
#{andrews}
thf(conj, conjecture,
  ![F:$i>$i]: ?[X:$i]: a @ (F @ X) @ X
).
"""

format_result res
# Timeout
```

```elixir
res = prove ~p"""
#{extensional}
thf(conj, conjecture,
  ![F:($i>$i)>$i>$i]: ?[X:$i>$i]: e @ (F @ X) @ X
).
"""

format_result res
# Timeout
```

