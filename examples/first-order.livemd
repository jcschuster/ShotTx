**Chain of length 5.**

```elixir
race(
  fn opts ->
    prove(
      ~p"""
      thf(a1, type, a1: $i).
      thf(a2, type, a2: $i).
      thf(a3, type, a3: $i).
      thf(a4, type, a4: $i).
      thf(a5, type, a5: $i).
      thf(e12, axiom, a1 = a2).
      thf(e23, axiom, a2 = a3).
      thf(e34, axiom, a3 = a4).
      thf(e45, axiom, a4 = a5).
      thf(conj, conjecture, a1 = a5).
      """,
      opts
    )
  end,
  configs
)
```

