**Two rewrites under a binary predicate.**

```elixir
race(
  fn opts ->
    prove(
      ~p"""
      thf(a, type, a: $i).
      thf(b, type, b: $i).
      thf(c, type, c: $i).
      thf(d, type, d: $i).
      thf(r, type, r: $i>$i>$o).
      thf(eq1, axiom, a = b).
      thf(eq2, axiom, c = d).
      thf(rac, axiom, r @ a @ c).
      thf(conj, conjecture, r @ b @ d).
      """,
      opts
    )
  end,
  configs
)
```

