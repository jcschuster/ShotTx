**McCarthy-style identity chain.**

```elixir
race(
  fn opts ->
    prove(
      ~p"""
      thf(a, type, a: $i).
      thf(b, type, b: $i).
      thf(c, type, c: $i).
      thf(d, type, d: $i).
      thf(f, type, f: $i>$i).
      thf(g, type, g: $i>$i).
      thf(e1, axiom, f @ a = b).
      thf(e2, axiom, g @ b = c).
      thf(e3, axiom, a = d).
      thf(conj, conjecture, g @ (f @ d) = c).
      """,
      opts
    )
  end,
  configs
)
```

