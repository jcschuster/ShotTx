```elixir
configs = [
  default: [timeout: 5_000],
  eager_leibniz: [
    timeout: 5_000,
    formula_cost: &Rules.rule_cost(&1, %{leibniz: 3})
  ],
  pattern_paramod: [
    timeout: 5_000,
    paramodulation_mode: :pattern
  ],
  no_paramod: [
    timeout: 5_000,
    paramodulation_mode: :matching
  ]
]
```

