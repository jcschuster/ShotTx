**Rewrite inside a quantified statement.**

```elixir
race(
  fn opts ->
    prove(
      ~p"""
      thf(f, type, f: $i>$i).
      thf(g, type, g: $i>$i).
      thf(p, type, p: $i>$o).
      thf(eq, axiom, ![X:$i]: f @ X = g @ X).
      thf(hyp, axiom, ![X:$i]: p @ (f @ X)).
      thf(conj, conjecture, ![X:$i]: p @ (g @ X)).
      """,
      opts
    )
  end,
  configs
)
```

