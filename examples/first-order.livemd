**Three-cycle.**

```elixir
race(
  fn opts ->
    prove(
      ~p"""
      thf(a, type, a: $i).
      thf(b, type, b: $i).
      thf(c, type, c: $i).
      thf(f, type, f: $i>$i).
      thf(fa, axiom, f @ a = b).
      thf(fb, axiom, f @ b = c).
      thf(fc, axiom, f @ c = a).
      thf(conj, conjecture, f @ (f @ (f @ a)) = a).
      """,
      opts
    )
  end,
  configs
)
```

