**Chain of length 8** — this is where Leibniz starts to drown.

```elixir
race(
  fn opts ->
    prove(
      ~p"""
      thf(a1, type, a1: $i).
      thf(a2, type, a2: $i).
      thf(a3, type, a3: $i).
      thf(a4, type, a4: $i).
      thf(a5, type, a5: $i).
      thf(a6, type, a6: $i).
      thf(a7, type, a7: $i).
      thf(a8, type, a8: $i).
      thf(e12, axiom, a1 = a2).
      thf(e23, axiom, a2 = a3).
      thf(e34, axiom, a3 = a4).
      thf(e45, axiom, a4 = a5).
      thf(e56, axiom, a5 = a6).
      thf(e67, axiom, a6 = a7).
      thf(e78, axiom, a7 = a8).
      thf(conj, conjecture, a1 = a8).
      """,
      opts
    )
  end,
  configs
)
