**`2 + 1 = 1 + 2`.**

```elixir
race(
  fn opts ->
    prove(
      ~p"""
      #{peano_axioms}
      thf(conj, conjecture,
        plus @ (s @ (s @ o)) @ (s @ o) = plus @ (s @ o) @ (s @ (s @ o))).
      """,
      opts
    )
  end,
  configs
)
